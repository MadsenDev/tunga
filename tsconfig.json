{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "outDir": "dist",
    "types": [
      "node",
      "vitest/globals"
    ],
    "noImplicitAny": false,
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "src",
    "tests",
    "tunga.config.ts"
  ]
}
